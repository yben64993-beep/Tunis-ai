rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Allow users to read and write their own profile document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // 2. Allow users to read, write, and delete their own chats and messages
      match /chats/{chatId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        
        match /messages/{messageId} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
        }
      }
    }

    // 3. Allow all users to read the AI knowledge base
    match /knowledge_base/{document=**} {
      allow read: if true;
      // Only the backend (Admin SDK) can write new knowledge
      allow write: if false;
    }
  }
}
